# Telegram机器人配置
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# 检查间隔配置（分钟）
CHECK_INTERVAL_MINUTES=60

# 插件配置
PUBLISHER=augment
EXTENSION=vscode-augment

# 日志级别
LOG_LEVEL=info

# 工作目录
WORK_DIR=./augment-plugins

# 是否启用自动清理旧版本
AUTO_CLEANUP=true

# 保留的版本数量（建议设为1，只保留最新版本）
KEEP_VERSIONS=1
